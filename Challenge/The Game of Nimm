# Total number of stones at the start of the game
stones = 20

# Player 1 starts first
current_player = 1

# Keep playing until no stones are left
while stones > 0:

    # Show how many stones are left
    print(f"There are {stones} stones left.")

    # Ask the current player how many stones they want to remove
    remove = int(input(f"Player {current_player} would you like to remove 1 or 2 stones? "))

    # Keep asking until the player enters a valid number
    while remove != 1 and remove != 2:
        remove = int(input("Please enter 1 or 2: "))

    # Remove the chosen number of stones from the pile
    stones -= remove

    # If stones become 0 or less, game ends
    if stones <= 0:
        break

    # Switch turns between Player 1 and Player 2
    if current_player == 1:
        current_player = 2
    else:
        current_player = 1

    # Print empty line for better readability
    print()

# After the loop ends, switch player to announce the winner
if current_player == 1:
    print("Player 2 wins!")
else:
    print("Player 1 wins!")
