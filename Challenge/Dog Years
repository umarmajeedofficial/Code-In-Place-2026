"""
This program converts a human's age (in calendar years) to dog years.
It uses a constant multiplier of 7.18 to perform the calculation.
"""

# Each year for a human is like 7.18 years for a dog
DOG_YEARS_MULTIPLIER = 7.18  

def main():
    # 1. Prompt the user for an age in calendar years.
    # We use float() so the user can enter ages like 3.5 years.
    calendar_years_str = input("Enter an age in calendar years: ")
    calendar_years = float(calendar_years_str)

    # 2. Calculate the age in dog years using the constant multiplier.
    dog_years = calendar_years * DOG_YEARS_MULTIPLIER

    # 3. Report the result back to the user.
    # We convert the result to a string to print it alongside the text.
    print("That's " + str(dog_years) + " in dog years!")


# This standard boilerplate ensures the program begins at the main() function.
if __name__ == '__main__':
    main()
