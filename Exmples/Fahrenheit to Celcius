"""
This program converts a temperature from Fahrenheit to Celsius.
It demonstrates the use of float (decimal) inputs and mathematical formulas.
"""

def main():
    # 1. Prompt the user for the temperature in Fahrenheit
    # We use float() because temperature can have decimal places (e.g., 98.6)
    fahrenheit_str = input("Enter temperature in Fahrenheit: ")
    fahrenheit = float(fahrenheit_str)

    # 2. Apply the conversion formula: C = (F - 32) * 5/9
    # The .0 ensures Python performs floating-point division
    celsius = (fahrenheit - 32) * 5.0 / 9.0

    # 3. Output the result
    # We convert the numbers back to strings to join them with the text
    print("Temperature: " + str(fahrenheit) + "F = " + str(celsius) + "C")


# Standard boilerplate to call the main function
if __name__ == '__main__':
    main()
