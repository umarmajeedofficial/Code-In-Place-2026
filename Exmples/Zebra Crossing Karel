"""
This program instructs Karel to create "Zebra Lines" (vertical stripes) 
across the world. Karel builds a double-column stripe, moves forward, 
and repeats the process until the wall is reached.
"""

from karel.stanfordkarel import *

def main():
    """
    Main loop: Karel continues to build stripes as long as there is 
    space ahead. After each stripe, Karel skips 4 spaces.
    """
    while front_is_clear():
        build_zebra_line()
        # Check again before moving to avoid hitting the far wall
        if front_is_clear():
            # Move 4 spaces forward to create a gap between stripes
            for i in range(4):
                if front_is_clear(): # Safety check for small worlds
                    move()

def build_zebra_line():
    """
    Creates a double-column vertical stripe of beepers.
    Karel goes up one column and down the next.
    """
    # --- Column 1: Go Up ---
    put_beeper()
    turn_left() 
    while front_is_clear():
        move()
        put_beeper()
    
    # --- Transition: Move to the next column ---
    turn_right()
    if front_is_clear():
        move()
        turn_right()
        
        # --- Column 2: Go Down ---
        put_beeper()
        while front_is_clear():
            move()
            put_beeper()
        turn_left() # Reset orientation to face East
    else:
        # If the world ends before the second column, reset orientation
        turn_right()
        turn_right()

def turn_right():
    """
    Helper function to turn Karel 270 degrees to the right.
    """
    turn_left()
    turn_left()
    turn_left()

# Entry point for the Karel execution environment
if __name__ == '__main__':
    main()
